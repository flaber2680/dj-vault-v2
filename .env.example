# App
# Use the public HTTPS origin, without a trailing slash.
NEXT_PUBLIC_APP_URL=https://vault.example.com
AUTH_URL=https://vault.example.com
# Keep runtime data outside the release directory and build artifacts.
DATA_DIRECTORY=/var/lib/dj-vault
# Required in production: 32+ random characters. Generate and store it privately.
AUTH_SECRET=replace-with-a-private-random-secret-of-at-least-32-characters

# Admin access is configured in lib/auth/admin.ts. No ADMIN_EMAIL environment
# variable is read by this application.

# Email for password reset
# Port 465: SMTP_SECURE=true, SMTP_STARTTLS=false
# Port 587: SMTP_SECURE=false, SMTP_STARTTLS=true
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_STARTTLS=false
SMTP_USER=mailbox@example.com
SMTP_PASS=replace-with-mailbox-password
SMTP_FROM="DJ Vault <mailbox@example.com>"
SMTP_ENVELOPE_FROM=mailbox@example.com

# S3-compatible storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=example-region
S3_BUCKET=example-bucket
S3_ADDRESSING_STYLE=virtual-hosted
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Payments
# Configure YooKassa notifications for payment.succeeded and payment.canceled:
# https://djvault.ru/api/payments/yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Temporarily enable the hidden admin-only 1-day / 100 RUB live smoke package.
PAYMENT_SMOKE_TEST_ENABLED=false
